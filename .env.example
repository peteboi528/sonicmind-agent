# MusicAgent (SonicMind) 环境变量示例
# 复制为 .env 后按需填写。留空的项走默认值；LLM_API_KEY 留空 → 启用 MockLLM（零依赖跑通全链路）。

# ───── LLM ─────
# 留空 → MockLLM（无需任何 key 即可跑通全链路，用于 demo/测试）
LLM_API_KEY=
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5
LLM_TIMEOUT_SECONDS=45
# 连接超时（建连阶段）：连接类卡死应快速失败，别等满 LLM_TIMEOUT_SECONDS
LLM_CONNECT_TIMEOUT=8
# 瞬时网络错误（连接重置/5xx/429）的重试次数；超时与 4xx 不重试
LLM_MAX_RETRIES=1
# 推理模型（deepseek-v4-flash 等）会先消耗 token 推理，建议 ≥2048 避免 content 被推理吃空
LLM_MAX_TOKENS=2048
# DeepSeek-V4「思考模式」开关：服务端默认 enabled（每次先吐 reasoning_content，用户看不到却要等）。
# 对结构化/闲聊小任务推理几乎无收益。默认 false 关掉——单次调用快约 35%、输出 token 少约 3 倍。
# 设 true 则全局恢复思考（真正需要推理的调用才值得）；配合 LLM_REASONING_EFFORT 控制强度。
LLM_THINKING=false
# 思考开启时的强度：low/medium→high，xhigh→max（仅 LLM_THINKING=true 时生效）
LLM_REASONING_EFFORT=high
# 温度三档：结构化任务 / 对话 / 文案生成
STRUCT_TASK_TEMPERATURE=0.1
DIALOG_TEMPERATURE=0.6
GENERATION_TEMPERATURE=0.7

# ───── 外部数据源（按需填写，留空则禁用对应源） ─────
EXTERNAL_SOURCE=netease
LASTFM_API_KEY=
TAVILY_API_KEY=

# ───── 存储 ─────
# 可选。相对路径始终相对项目根目录；留空时会只读选择已有歌曲最多的历史 store。
STORE_ROOT=
MEDIA_ROOT=data/media
RESOURCE_LIBRARY_PATH=data/resource_library.sqlite
ALLOWED_ORIGINS=*

# ───── 推荐参数 ─────
DAILY_REC_COUNT=25
ENABLE_ONLINE_ENRICH=false
ENABLE_RERANK=true
# Deep/Agentic 模式：复合多步任务走真迭代 ReAct（仅真实 LLM 下生效）
ENABLE_DEEP_MODE=true
# 三锚精排权重（自动归一化；缺项时重分配给其余锚）
TRI_ANCHOR_W_SEMANTIC=0.45
TRI_ANCHOR_W_PERSONAL=0.30
TRI_ANCHOR_W_BEHAVIOR=0.25
# 可选第四锚：协同过滤。无共现数据时自动回落三锚。
TRI_ANCHOR_W_COLLABORATIVE=0.20
# MMR 多样性重排：λ 越大越偏相关性，越小越偏多样性
MMR_LAMBDA=0.7
# Thompson Sampling 尾部探索比例
EXPLORATION_RATIO=0.2

# ───── Embedding 检索（Phase 3）─────
# auto：装了 sentence-transformers 自动启用，否则回退 TF cosine + 同义词 boost
ENABLE_EMBEDDINGS=auto
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ───── Bot 适配器（留空禁用）─────
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
WECHAT_TOKEN=
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# ───── API 鉴权（部署/多租户用，本地 demo 默认关闭）─────
# AUTH_ENABLED=true 时，除公开端点（/health /docs 等）外所有请求需带 X-API-Key。
# USER_API_KEYS 非空时启用 per-user key：服务端用 key 解析 user_id，并覆盖客户端传入的 user_id。
# 格式：USER_API_KEYS=user_a:key-a,user_b:key-b
# USER_API_KEYS 留空时退回共享 API_KEY，只做访问门禁，兼容本地/旧部署。
AUTH_ENABLED=false
API_KEY=
USER_API_KEYS=
